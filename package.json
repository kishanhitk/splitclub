{
  "name": "splitclub",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "expo start --android",
    "android:doctor": "bunx expo-doctor",
    "android:prebuild": "expo prebuild --platform android",
    "android:run": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:migrate:local": "wrangler d1 migrations apply splitclub --local",
    "db:migrate:remote": "wrangler d1 migrations apply splitclub --remote",
    "cloudflare:check": "bash scripts/check-cloudflare.sh",
    "cloudflare:provision": "bash scripts/provision-cloudflare.sh",
    "worker:dev": "wrangler dev worker/index.ts",
    "worker:deploy": "wrangler deploy",
    "worker:smoke": "bash scripts/smoke-worker.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tamagui/config": "^2.0.0-rc.41",
    "expo": "^55.0.23",
    "expo-auth-session": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-status-bar": "^55.0.6",
    "expo-system-ui": "~55.0.17",
    "expo-web-browser": "~55.0.15",
    "hono": "^4.12.18",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "tamagui": "^2.0.0-rc.41",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "typescript": "~5.9.2",
    "wrangler": "^4.90.0"
  },
  "private": true
}
